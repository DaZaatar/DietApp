APP_NAME=DietApp
ENV=dev
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite:///./dietapp_dev.db
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MEDIA_BACKEND=local
MEDIA_LOCAL_ROOT=uploads

# Auth (JWT). Set JWT_SECRET to a long random string in production.
JWT_SECRET=dev-only-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=10080
# Local dev: allow X-User-Id without login. Set false in production.
ALLOW_DEV_USER_HEADER=true
ALLOW_DEFAULT_USER=true
